# OpenClaw WeChat Bridge 默认配置

# HTTP 服务器配置
PORT=3001
HOST=0.0.0.0

# Wechaty 配置
WECHATY_NAME=openclaw-wechat
WECHATY_PUPPET=wechaty-puppet-wechat
WECHATY_PUPPET_TOKEN=

# 会话和持久化配置
WECHATY_MEMORY_CARD_PATH=./data

# 自动重连配置
WECHATY_RECONNECT_INTERVAL=5000
WECHATY_MAX_RECONNECT_ATTEMPTS=10
WECHATY_HEARTBEAT_INTERVAL=30000

# 联系人缓存配置
WECHATY_CONTACTS_CACHE_TTL=300000

# 日志配置
LOG_LEVEL=info                    # 可选: debug, info, warn, error
LOG_DIR=./logs                    # 日志文件目录
LOG_ENABLE_FILE=true              # 是否写入日志文件
LOG_ENABLE_CONSOLE=true           # 是否输出到控制台
LOG_MAX_FILE_SIZE=10485760        # 单个日志文件最大大小 (10MB)
LOG_MAX_FILES=5                   # 保留的日志文件数量

# 监控告警配置（可选）
ALERT_WEBHOOK_URL=                # 告警 Webhook 地址
ALERT_ENABLED=false               # 是否启用告警

# Webhook 配置（可选，通常由插件注册）
WEBHOOK_URL=
