{
  "name": "@canghe/openclaw-wechat",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw WeChat channel plugin via Proxy API",
  "license": "MIT",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "package.json",
    "tsconfig.json",
    ".env",
    ".env.example",
    "start-bridge.sh",
    "setup.sh",
    "configure-openclaw.sh",
    "openclaw-wechat.service"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woniu/openclaw-wechat.git"
  },
  "keywords": [
    "openclaw",
    "wechat",
    "微信",
    "chatbot",
    "ai",
    "claude"
  ],
  "openclaw": {
    "id": "openclaw-wechat",
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "openclaw-wechat",
      "label": "WeChat",
      "selectionLabel": "WeChat (微信)",
      "docsPath": "/channels/wechat",
      "docsLabel": "wechat",
      "blurb": "WeChat channel via Proxy API. 购买 API Key 请联系客服",
      "order": 80
    },
    "install": {
      "npmSpec": "@canghe/openclaw-wechat",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "memory-card": "^1.1.2",
    "qrcode-terminal": "^0.12.0",
    "wechaty": "^1.20.2",
    "wechaty-puppet-wechat4u": "^1.14.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "openclaw": ">=2026.2.9",
    "prettier": "^3.2.0",
    "supertest": "^6.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.9"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:old": "npx tsx test-channel.ts",
    "test:plugin": "npx tsx test-plugin.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start:bridge": "npx tsx src/bridge/server.ts"
  }
}
